# Google OAuth credentials — create at console.cloud.google.com
# Enable: Gmail API, Google Calendar API, Google People API
GOOGLE_CLIENT_ID=your_client_id_here
GOOGLE_CLIENT_SECRET=your_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:3001/api/auth/google/callback

# Where this server runs
PORT=3001

# Secret for signing RSVP tokens (any random string, keep private)
RSVP_SECRET=change_this_to_a_random_string

# URL the React app is served from (for CORS)
CLIENT_ORIGIN=https://claude.ai
