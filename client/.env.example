# Friend Radar — client build config
# Copy to .env.local and edit as needed.

# ─── Backend mode ────────────────────────────────────────────────────────────
# VITE_BACKEND controls where data is stored.
#
#   (unset or "local")  — IndexedDB in the browser. No server required.
#                         Great for personal use or GitHub Pages deploys.
#                         Data is browser-local; clearing storage loses data.
#                         Export backups regularly (Friends tab → Export backup).
#
#   "server"            — Express + SQLite backend (npm run server).
#                         Enables Google Calendar, email/iMessage invites,
#                         Apple Contacts sync, cross-device access, and the
#                         cascade invite worker. Each self-hoster runs their
#                         own server with their own Google OAuth credentials.
#
VITE_BACKEND=local

# ─── Server URL (server mode only) ───────────────────────────────────────────
# Leave blank when the Express server serves the built client (same origin).
# Set to the server's base URL when running them on different hosts/ports.
#
# Examples:
#   VITE_SERVER_URL=          (same origin — default for production self-host)
#   VITE_SERVER_URL=http://localhost:3001   (dev: separate Vite + Express)
#   VITE_SERVER_URL=https://radar.example.com
#
# VITE_SERVER_URL=
